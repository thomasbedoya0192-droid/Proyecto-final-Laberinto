/**
 * Main.jack: Punto de entrada del proyecto Maze Intelligence.
 * Construye el juego (mapa + jugador), ejecuta el bucle principal y
 * libera la memoria al terminar.
 */
class Main {
    function void main() {
        var PlayerGame game;
        let game = PlayerGame.new();
        do game.run();
        do game.dispose();
        return;
    }
}
